set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESTORE_PY="$SCRIPT_DIR/wayland/kwin_restore.py"

# -- Bypass dialogs for dry-run -----------------------------------------------
for arg in "$@"; do
    if [[ "$arg" == "--dry-run" ]]; then
        exec python3 "$RESTORE_PY" "$@"
    fi
done

# -- Dialog 1: Ready to restore? ----------------------------------------------
# --warningcontinuecancel returns 0 for Continue, non-zero for Cancel.
if ! kdialog \
        --title "Desktop Setup — Getting Started" \
        --warningcontinuecancel \
        $'If you have installed a user-specifc setup script, it will run next.\nIf you use the Secret Service protocol,\nyou must Unlock your Password Manager\nduring the next step.' \
        2>/dev/null; then
    exit 0
fi


# -- Locate user hook scripts via user_scripts_folder from config -------------
# Read user_scripts_folder from config.yaml (default: "./" = project root).
# Relative paths are resolved against SCRIPT_DIR.
# If getconfig fails for any reason, fall back to the project root.
_raw_folder="$(python3 "$SCRIPT_DIR/wayland/kwin_getconfig.py" lookup user_scripts_folder 2>/dev/null || echo "./")"

# Expand ~ and resolve relative paths against SCRIPT_DIR
_raw_folder="${_raw_folder/#\~/$HOME}"
if [[ "$_raw_folder" != /* ]]; then
    _raw_folder="$SCRIPT_DIR/$_raw_folder"
fi
# Canonicalise (remove trailing slashes, resolve . and ..)
USER_SCRIPTS_FOLDER="$(cd "$_raw_folder" 2>/dev/null && pwd || echo "$SCRIPT_DIR")"

# -- Run restore-user-before if present ---------------------------------------
# Typical use: launch background apps (e.g. VPNs, SSH agents, servers)
# that kwin_restore.py will expect to be running.
_user_before="$USER_SCRIPTS_FOLDER/restore-user-before"
if [[ -x "$_user_before" ]]; then
    "$_user_before"
fi

# -- Check whether the Secret Service is required by the current config -------
# Reads use_secret_service from config.yaml.  If the key is absent or getconfig
# fails for any reason, we default to "false" (no check performed), so the
# behaviour is unchanged for installs that don't use the Secret Service.
_use_ss="$(python3 "$SCRIPT_DIR/wayland/kwin_getconfig.py" lookup use_secret_service 2>/dev/null || echo "false")"

# -- Dialog 2: Pop-up warning (with Secret Service readiness loop) ------------
# If use_secret_service is enabled, we probe the Secret Service after the user
# clicks Continue.  If it is not responding yet (e.g. KeePassXC is not yet
# unlocked after a reboot), we show a brief sorry dialog and loop back to
# Dialog #2, giving the user another chance to unlock the password manager.
# The loop exits as soon as:
#   (a) the user cancels, or
#   (b) use_secret_service is false (no probe required), or
#   (c) the Secret Service probe succeeds.
while true; do
    if ! kdialog \
            --title "Desktop Setup - Ready to Start" \
            --warningcontinuecancel \
            $'If you use the Secret Service protocol, make sure your Password Manager is unlocked before you continue.\nIf you are ready to proceed: WATCH OUT for Pop-Up Approval Messages!\n\n(They may appear UNDER other Windows!)' \
            2>/dev/null; then
        exit 0
    fi

    # No Secret Service requirement — proceed immediately.
    if [[ "$_use_ss" != "true" ]]; then
        break
    fi

    # Secret Service is required — probe it now by attempting to fetch every
    # {PASS key} token from the snapshot.  Exits 0 only if all keys succeed;
    # exits 1 if any key is blocked (dismissed dialog, locked collection, etc.)
    if python3 "$SCRIPT_DIR/wayland/kwin_secret_service.py" check-ready 2>/dev/null; then
        # Service is up — proceed.
        break
    fi

    # Service is not responding.  Prompt the user and loop back to Dialog #2.
    kdialog \
        --title "Desktop Setup — Secret Service Not Ready" \
        --sorry \
        $'The Secret Service is not responding.\n\nPlease unlock your Password Manager, then click OK to try again.' \
        2>/dev/null || true
    # Loop back to Dialog #2.
done

# -- Run the Python restore script --------------------------------------------
# Not exec'd (unlike --dry-run above) so we can run restore-user-after below.
_restore_exit=0
python3 "$RESTORE_PY" "$@" || _restore_exit=$?

# -- Run restore-user-after if present ----------------------------------------
# Called regardless of whether kwin_restore.py succeeded or failed.
# Typical use: post-restore tasks such as opening a terminal, sending a
# notification, or cleaning up temporary state created by restore-user-before.
# The original exit code of kwin_restore.py is re-applied after this hook.
_user_after="$USER_SCRIPTS_FOLDER/restore-user-after"
if [[ -x "$_user_after" ]]; then
    "$_user_after"
fi

exit "$_restore_exit"

